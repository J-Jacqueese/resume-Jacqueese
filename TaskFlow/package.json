{
  "name": "taskflow",
  "private": true,
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"pnpm --filter @taskflow/api dev\" \"pnpm --filter @taskflow/web dev\"",
    "build": "pnpm --filter @taskflow/web build",
    "test": "pnpm --filter @taskflow/api test"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "@prisma/engines", "esbuild", "prisma"]
  }
}
